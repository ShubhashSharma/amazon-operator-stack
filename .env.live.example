# Live demo credentials — used by `npm run demo` and `npm run setup:prefilled`.
#
# Copy this file to `.env.live` and either:
#   (a) Fill in real Seller Central values for a real-data run, OR
#   (b) Use plausible-looking placeholders if you'll route through the mock
#       (placeholders work because the mock doesn't validate them).
#
# The wizard reads this file when called with --prefilled and pre-populates
# every prompt that has a matching value. Each stage that finds prefilled data
# short-circuits with a "✓ prefilled" log line instead of prompting.
#
# .env.live is git-ignored by default — never commit it.

# --- Required for skipping stages 4 + 5 (LWA app + refresh token) ---
SP_API_CLIENT_ID=amzn1.application-oa2-client.MOCK_CLIENT_ID_XXXXXXXXXXXXXXXX
SP_API_CLIENT_SECRET=amzn1.oa2-cs.v1.MOCK_SECRET_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SP_API_REFRESH_TOKEN=Atzr|MOCK_VALID_REFRESH_TOKEN_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional — friendly name shown to the audience
SP_API_APP_NAME=Operator Command Centre

# --- Optional: skips stages 2 + 3 (region + marketplace pick) too ---
# Region is auto-derived from SP_API_MARKETPLACE_ID; you can omit SP_API_REGION.
SP_API_MARKETPLACE_ID=A1F83G8C2ARO7P
SP_API_ENABLED_MARKETPLACE_IDS=A1F83G8C2ARO7P,A1PA6795UKMFR9
