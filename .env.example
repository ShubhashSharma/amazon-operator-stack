# amazon-operator-stack — environment template.
#
# This file is the SHAPE of what your real .env will look like after running
# the wizard. The wizard generates the real .env for you — you should not have
# to fill any of this in by hand.
#
# To start the wizard: npm run setup

# ─── SP-API (read-only) ───────────────────────────────────────────────
# LWA app credentials from Seller Central → Apps & Services → Develop Apps.
SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SP_API_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SP_API_REFRESH_TOKEN=Atzr|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Primary marketplace + region.
# Common: UK=A1F83G8C2ARO7P, US=ATVPDKIKX0DER, DE=A1PA6795UKMFR9.
# All marketplaces the server is allowed to read from (comma-separated).
SP_API_MARKETPLACE_ID=A1F83G8C2ARO7P
SP_API_MARKETPLACE_CODE=GB
SP_API_ENABLED_MARKETPLACE_IDS=A1F83G8C2ARO7P

# Region codes:
#   eu-west-1 for UK / DE / FR / IT / ES / NL / SE / PL / BE / TR
#   us-east-1 for US / CA / MX / BR
#   us-west-2 for JP / AU / SG / IN
SP_API_REGION=eu-west-1

# Endpoints (one per region):
#   https://sellingpartnerapi-eu.amazon.com  (Europe)
#   https://sellingpartnerapi-na.amazon.com  (North America)
#   https://sellingpartnerapi-fe.amazon.com  (Far East)
SP_API_ENDPOINT=https://sellingpartnerapi-eu.amazon.com

# ─── Ads API (homework, see HOMEWORK.md) ──────────────────────────────
# Leave as "not-configured" until you've completed the Ads API homework.
# The server treats these placeholders as "Ads API disabled".
ADS_API_CLIENT_ID=not-configured
ADS_API_CLIENT_SECRET=not-configured
ADS_API_REFRESH_TOKEN=not-configured
ADS_API_REGION=EU
ADS_API_ENDPOINT=https://advertising-api-eu.amazon.com
ADS_PROFILE_ID=

# ─── Server behaviour ─────────────────────────────────────────────────
# Logging level: debug | info | warn | error
LOG_LEVEL=info
